---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  timer?: boolean;
  footer?: boolean;
  extraStyles?: string[];
}

const { title, timer = false, footer = true, extraStyles = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  {extraStyles.map(href => <link rel="stylesheet" href={href} />)}
</head>
<body>
  <Header timer={timer} />
  <slot />
  {footer && <Footer />}
</body>
</html>
