---
import { getCollection } from 'astro:content';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order);
const modules = (await getCollection('modules')).sort((a, b) => a.data.order - b.data.order);
const allSections = (await getCollection('sections')).sort(
  (a, b) => a.data.moduleOrder - b.data.moduleOrder || a.data.sectionOrder - b.data.sectionOrder
);

function isActive(href: string) {
  return currentPath === href || currentPath === `${href}/`;
}

function isInModule(moduleSlug: string) {
  const prefix = `/training/module/${moduleSlug}`;
  return currentPath === prefix || currentPath.startsWith(`${prefix}/`);
}

const inProgram = programs.some(p => isActive(`/training/${p.data.slug}`));
const inModules = currentPath.startsWith('/training/module/');
---

<nav class="sidebar" id="sidebar" aria-label="Training navigation">
  <button
    class:list={['nav-section', 'nav-section-toggle', { collapsed: !inProgram }]}
    id="program-toggle"
    aria-expanded={inProgram ? 'true' : 'false'}
    aria-controls="program-items"
  >
    <span>Program</span>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class:list={['nav-section-items', { collapsed: !inProgram }]} id="program-items" role="region" aria-labelledby="program-toggle">
    <div class="nav-section-inner">
      {programs.map((p) => (
        <a
          class:list={['nav-item', { active: isActive(`/training/${p.data.slug}`) }]}
          href={`/training/${p.data.slug}`}
          aria-current={isActive(`/training/${p.data.slug}`) ? 'page' : undefined}
        >
          {p.data.title}
        </a>
      ))}
    </div>
  </div>

  <button
    class:list={['nav-section', 'nav-section-toggle', { collapsed: !inModules }]}
    id="modules-toggle"
    aria-expanded={inModules ? 'true' : 'false'}
    aria-controls="modules-items"
  >
    <span>Training Modules</span>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
      <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <div class:list={['nav-section-items', { collapsed: !inModules }]} id="modules-items" role="region" aria-labelledby="modules-toggle">
  <div class="nav-section-inner">
  {modules.map((m) => {
    const moduleHref = `/training/module/${m.data.slug}`;
    const inModule = isInModule(m.data.slug);
    const moduleSections = allSections.filter(s => s.data.module === m.data.slug);
    const subItemsId = `sub-${m.data.slug}`;

    return (
      <div class="nav-module-group" data-module={m.data.slug}>
        <div class:list={['nav-item', 'nav-module', { active: isActive(moduleHref), expanded: inModule }]}>
          <a href={moduleHref} class="nav-module-link" aria-current={isActive(moduleHref) ? 'page' : undefined}>
            <span>{m.data.order === 0 ? m.data.title : `${m.data.order}. ${m.data.title}`}</span>
          </a>
          <div class="nav-module-right">
            <span class="nav-weight">{m.data.weight ?? '—'}</span>
            <button
              class="nav-toggle"
              aria-label={`Toggle ${m.data.title} sections`}
              aria-expanded={inModule ? 'true' : 'false'}
              aria-controls={subItemsId}
            >
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
        <div class:list={['nav-sub-items', { collapsed: !inModule }]} id={subItemsId} role="region">
          <div class="nav-sub-inner">
            {moduleSections.map((s) => {
              const sectionHref = `/training/module/${m.data.slug}/${s.data.slug}`;
              return (
                <a
                  class:list={['nav-item', 'nav-sub-item', { active: isActive(sectionHref) }]}
                  href={sectionHref}
                  aria-current={isActive(sectionHref) ? 'page' : undefined}
                >
                  {s.data.title}
                </a>
              );
            })}
          </div>
        </div>
      </div>
    );
  })}
  </div>
  </div>
</nav>

<script>
  // Module section toggles (expand/collapse individual module's sections)
  document.querySelectorAll('.nav-toggle').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const group = (btn as HTMLElement).closest('.nav-module-group')!;
      const subItems = group.querySelector('.nav-sub-items')!;
      const navModule = group.querySelector('.nav-module')!;
      const isCollapsed = subItems.classList.contains('collapsed');

      subItems.classList.toggle('collapsed');
      navModule.classList.toggle('expanded', isCollapsed);
      btn.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
    });
  });

  // Section heading toggles (collapse entire Program / Training Modules groups)
  document.querySelectorAll('.nav-section-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const items = btn.nextElementSibling as HTMLElement;
      const isCollapsed = items.classList.contains('collapsed');
      items.classList.toggle('collapsed');
      btn.classList.toggle('collapsed', !isCollapsed);
      btn.setAttribute('aria-expanded', isCollapsed ? 'true' : 'false');
    });
  });

  // Scroll the active nav item into view
  const activeItem = document.querySelector('.nav-sub-item.active') || document.querySelector('.nav-item.active');
  activeItem?.scrollIntoView({ block: 'nearest', behavior: 'instant' });
</script>
